# ============================================================
# CREDIT-CARD-MLOPS – Environment Variables Template
# Copy to .env and fill in values before running docker-compose
# ============================================================

# User / project tag (used in container names)
USER=student

# ============================================================
# MLFlow
# ============================================================
MLFLOW_PORT=5000
MODEL_NAME=credit_card_propensity
MODEL_STAGE=Production

# ============================================================
# MinIO  (S3-compatible artifact store)
# ============================================================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET_NAME=mlflow-artifacts

# ============================================================
# PostgreSQL  (MLFlow backend)
# ============================================================
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow

# ============================================================
# Grafana
# ============================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================
# API
# ============================================================
API_PORT=8000

# ============================================================
# Evidently
# ============================================================
EVIDENTLY_PORT=8001
EVIDENTLY_DRIFT_THRESHOLD=0.1
EVIDENTLY_MIN_SAMPLES=100
